{
  "mcpServers": {
    "stock_translations": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "./mcp-servers/stock-translations",
        "tinboker-stock-translations-mcp"
      ],
      "env": {
        "TINBOKER_API_BASE_URL": "https://dev-api.tinboker.com"
      }
    },
    "article_authoring": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "./mcp-servers/article-authoring",
        "tinboker-article-authoring-mcp"
      ],
      "env": {
        "TINBOKER_API_BASE_URL": "https://dev-api.tinboker.com",
        "TINBOKER_WEB_BASE_URL": "https://dev.tinboker.com"
      }
    },
    "podcast_regen": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "pipelines",
        "--package",
        "tinboker-podcast",
        "python",
        "services/podcast/regen_mcp.py"
      ],
      "env": {
        "GCP_PROJECT_ID": "gen-lang-client-0901363254",
        "FIRESTORE_DATABASE_ID": "graphfolio-db",
        "TINBOKER_PLATFORM_API_URL": "http://localhost:5174"
      }
    }
  }
}
