# ============================================================================
# TinBoker — CANONICAL Caddy reverse-proxy config (host systemd service)
# ============================================================================
# THIS FILE IS DEPLOYED. .github/workflows/backend-deploy.yml syncs it to
# /etc/caddy/Caddyfile on the VPS on every dev/staging/prod backend deploy:
# it `caddy validate`s this file, copies it to /etc/caddy/Caddyfile, then runs
# `systemctl reload caddy`. Caddy runs as a HOST systemd service (User=caddy,
# caddy v2.10.x) — NOT a Docker container.
#
# To change routing: edit THIS file → PR → merge. Do NOT hand-edit
# /etc/caddy/Caddyfile on the VPS; it is overwritten on the next deploy.
#
# One shared Netdata (localhost:19999) serves every env's /netdata/*.
# ============================================================================

# TinBoker Caddyfile
# Multi-environment setup
# 
# Frontend: Served by Cloudflare Pages (tinboker.com, www.tinboker.com)
# Backend: Served by VPS (api.tinboker.com, dev-api.tinboker.com, staging-api.tinboker.com)

# ==========================================
# Production API: api.tinboker.com (port 8000)
# With Netdata monitoring on /netdata/*
# ==========================================
api.tinboker.com {
	encode gzip

	# Netdata monitoring dashboard
	handle /netdata/* {
		uri strip_prefix /netdata
		reverse_proxy localhost:19999
	}

	# Default: API proxy
	handle {
		reverse_proxy localhost:8000
	}

	log {
		output file /var/log/caddy/api-access.log
		format json
	}
}

# ==========================================
# Development API: dev-api.tinboker.com (port 8001)
# ==========================================
dev-api.tinboker.com {
	encode gzip

	# Netdata monitoring dashboard
	handle /netdata/* {
		uri strip_prefix /netdata
		reverse_proxy localhost:19999
	}

	# Default: API proxy
	handle {
		reverse_proxy localhost:8001
	}

	log {
		output file /var/log/caddy/dev-api-access.log
		format json
	}
}

# ==========================================
# Staging API: staging-api.tinboker.com (port 8002)
# With Netdata monitoring on /netdata/*
# ==========================================
staging-api.tinboker.com {
	encode gzip

	# Netdata monitoring dashboard
	handle /netdata/* {
		uri strip_prefix /netdata
		reverse_proxy localhost:19999
	}

	# Default: API proxy
	handle {
		reverse_proxy localhost:8002
	}

	log {
		output file /var/log/caddy/staging-api-access.log
		format json
	}
}

# ==========================================
# Development Frontend: dev.tinboker.com
# (Still served from VPS for development)
# ==========================================
dev.tinboker.com {
	encode gzip

	handle /api/* {
		reverse_proxy localhost:8001
	}

	handle /ws/* {
		reverse_proxy localhost:8001
	}

	handle /health {
		reverse_proxy localhost:8001
	}

	handle {
		root * /var/www/html-dev
		try_files {path} /index.html
		file_server
	}

	log {
		output file /var/log/caddy/dev-access.log
		format json
	}
}

# ==========================================
# Direct IP access (for health checks)
# ==========================================
:80 {
	encode gzip

	handle /api/* {
		reverse_proxy localhost:8000
	}

	handle /health {
		reverse_proxy localhost:8000
	}

	respond "VPS is running" 200
}

# ==========================================
# Podcast / Wiki content API: podcast-api.tinboker.com (port 8003)
# tinboker-agents — /api/podcast/*, /api/episodes/*, /api/wiki/*
# ==========================================
podcast-api.tinboker.com {
	encode gzip

	# Static media files (Phase E: GCS -> VPS blob store)
	handle /media/* {
		root * /var/lib/tinboker
		file_server
	}

	# Content API
	handle {
		reverse_proxy localhost:8003
	}

	log {
		output file /var/log/caddy/podcast-api-access.log
		format json
	}
}
