# Podcast Pipeline Environment Variables
# All secrets are loaded from Google Secret Manager at runtime.
# This file documents what's needed — do NOT commit actual values.

# === Required for content generation (LangGraph pipeline) ===
OPENROUTER_API_KEY=        # OpenRouter API key (https://openrouter.ai/keys)

# === Required for transcription ===
GROQ_API_KEY=              # Groq Whisper STT

# === Required for storage ===
GCP_CREDENTIALS_JSON=      # Base64 or JSON string for GCS/Firestore auth
FIRESTORE_DATABASE_ID=     # Firestore database ID

# === Required for API auth ===
PODCAST_API_KEY=           # X-API-Key header for podcast API

# === Optional ===
SPOTIFY_ID=                # Spotify metadata enrichment
SPOTIFY_SECRET=
LANGSMITH_API_KEY=         # LangSmith tracing (optional but recommended)

# === LLM model (required) ===
# One switch var for every pipeline role. Prefix with openrouter:.
PIPELINE_LLM_MODEL=openrouter:deepseek/deepseek-v4-pro
# Optional per-role overrides (take precedence over PIPELINE_LLM_MODEL):
# EXTRACTOR_MODEL=
# WRITER_MODEL=
# MARP_WRITER_MODEL=
# TICKER_EXTRACTOR_MODEL=
# KEY_INSIGHTS_EXTRACTOR_MODEL=
# SOCIAL_COPY_WRITER_MODEL=
